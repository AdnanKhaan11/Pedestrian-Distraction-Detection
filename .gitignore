# ================================
# 🔐 ENV & SECRETS (CRITICAL)
# ================================
.env
.env.*
*.env
*.key
*.pem
*.crt
secrets.yaml
configs/*secret*.yaml
youfocus/

# ================================
# 🧠 MODELS & ARTIFACTS
# ================================
artifacts/
models/
*.pt
*.pth
*.ckpt
*.h5
*.onnx
*.pkl
*.joblib

# ================================
# 📊 DATA (RAW / PROCESSED)
# ================================
data/raw/
data/interim/
data/processed/
*.csv
*.tsv
*.jsonl
*.parquet
*.feather

# (Optional: allow sample data)
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# ================================
# 📈 LOGS & OUTPUTS
# ================================
logs/
*.log
wandb/
mlruns/
tensorboard/
runs/

# ================================
# 🐍 PYTHON CACHE
# ================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.py,cover

# ================================
# 🧪 TEST & COVERAGE
# ================================
.coverage
coverage.xml
htmlcov/
.pytest_cache/

# ================================
# 📦 BUILD FILES
# ================================
build/
dist/
*.egg-info/
.eggs/

# ================================
# 🧰 IDE / EDITOR
# ================================
.vscode/
.idea/
*.swp
*.swo

# ================================
# 🖥️ OS FILES
# ================================
.DS_Store
Thumbs.db

# ================================
# 🐳 DOCKER
# ================================
*.tar

# ================================
# 📓 NOTEBOOKS
# ================================
.ipynb_checkpoints/

# ================================
# ⚙️ CACHE / TEMP
# ================================
tmp/
temp/
.cache/

