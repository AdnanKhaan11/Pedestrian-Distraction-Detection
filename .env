# ── API Settings ──────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
RELOAD=true
SECRET_KEY=your-secret-key-change-in-production

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# ── Paths ─────────────────────────────────────
PROJECT_ROOT=../
CONFIGS_DIR=../configs
ARTIFACTS_DIR=../artifacts

# ── Device ────────────────────────────────────
DEVICE=auto
LOG_LEVEL=INFO

# ── Detection ─────────────────────────────────
FRAME_INTERVAL_MS=500
MAX_PERSONS_PER_FRAME=10

# ── Face Recognition ──────────────────────────
FACE_EMBEDDING_MODEL=facenet-pytorch
FACE_SIMILARITY_THRESHOLD=0.85
FACE_EMBEDDING_DIM=512

# ── Alert Thresholds ──────────────────────────
ALERT_HIGH_POSTURE_CONFIDENCE=0.90
ALERT_HIGH_PHONE_REQUIRED=true
ALERT_MEDIUM_POSTURE_CONFIDENCE=0.75
ALERT_MEDIUM_PHONE_REQUIRED=true
ALERT_LOW_POSTURE_STATE=suspicious

# ── Data Retention ────────────────────────────
DETECTION_RETENTION_DAYS=30

# ── Training ──────────────────────────────────
ALLOW_CONCURRENT_TRAINING=false

# ── Debug ─────────────────────────────────────
DEBUG=false