MONGODB_URI=mongodb://adnankhaan44:Cluster123@ac-fx7at7o-shard-00-00.ybuqe6t.mongodb.net:27017,ac-fx7at7o-shard-00-01.ybuqe6t.mongodb.net:27017,ac-fx7at7o-shard-00-02.ybuqe6t.mongodb.net:27017/?ssl=true&replicaSet=atlas-yfpssj-shard-0&authSource=admin&appName=Cluster0

DB_NAME=pedestrian_detection

# Backend API Configuration
API_HOST=0.0.0.0
API_PORT=8000
RELOAD=true
SECRET_KEY=your-secret-key-change-in-production

# CORS Configuration
# Frontend is running on http://localhost:5173 (Vite)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# ML Model & Paths (relative to project root)
PROJECT_ROOT=../
CONFIGS_DIR=../configs
ARTIFACTS_DIR=../artifacts

# System Configuration
DEVICE=auto
LOG_LEVEL=INFO

# Inference Settings
FRAME_INTERVAL_MS=500
MAX_PERSONS_PER_FRAME=10

# Face Embedding Configuration
FACE_EMBEDDING_MODEL=facenet-pytorch
FACE_SIMILARITY_THRESHOLD=0.85
FACE_EMBEDDING_DIM=512

# Alert Thresholds
ALERT_HIGH_POSTURE_CONFIDENCE=0.90
ALERT_HIGH_PHONE_REQUIRED=true
ALERT_MEDIUM_POSTURE_CONFIDENCE=0.75
ALERT_MEDIUM_PHONE_REQUIRED=true
ALERT_LOW_POSTURE_STATE=suspicious

# Database Retention
DETECTION_RETENTION_DAYS=30

# Training
ALLOW_CONCURRENT_TRAINING=false

# Debug Mode
DEBUG=false
